<Window x:Class="KeyboardTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Trainer"
        Height="600"
        Width="900"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <ScrollViewer>
        <StackPanel Margin="10">

            <WrapPanel Margin="0 0 0 10">

                <TextBlock Text="Скорость: "
                           FontWeight="Bold"/>

                <TextBlock x:Name="txtSpeed"
                           Text="0"
                           Width="50"/>

                <TextBlock Text="Ошибки:"
                           Margin="20 0 0 0"
                           FontWeight="Bold"/>

                <TextBlock x:Name="txtErrors"
                           Text="0"
                           Width="50"/>

                <TextBlock Text="Длина:"
                           Margin="20 0 0 0"
                           FontWeight="Bold"/>

                <Slider x:Name="slLength"
                        Width="150"
                        Minimum="5"
                        Maximum="50"
                        Value="10"/>

                <CheckBox x:Name="cbCase"
                          Margin="20 0 0 0"
                          Content="Учитывать регистр"/>

            </WrapPanel>

            <WrapPanel Margin="0 0 0 10">

                <Button x:Name="btnStart"
                        Width="100"
                        Height="35"
                        Content="Start"
                        Click="btnStart_Click"/>

                <Button x:Name="btnStop"
                        Width="100"
                        Height="35"
                        Margin="10 0 0 0"
                        Content="Stop"
                        Click="btnStop_Click"/>

            </WrapPanel>

            <TextBlock Text="Текст:"
                       FontWeight="Bold"
                       FontSize="16"/>

            <Border BorderBrush="Black"
                    BorderThickness="1"
                    Margin="0 5 0 10"
                    Padding="5">

                <TextBlock x:Name="txtTask"
                           FontSize="24"
                           TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="Ввод:"
                       FontWeight="Bold"
                       FontSize="16"/>

            <Border BorderBrush="Black"
                    BorderThickness="1"
                    Margin="0 5 0 20"
                    Padding="5">

                <TextBlock x:Name="txtInput"
                           FontSize="24"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- 1 ряд -->

            <UniformGrid Columns="10"
                         Margin="0 0 0 5">

                <Button x:Name="Q" Content="Q" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="W" Content="W" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="E" Content="E" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="R" Content="R" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="T" Content="T" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="Y" Content="Y" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="U" Content="U" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="I" Content="I" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="O" Content="O" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="P" Content="P" Height="45" IsHitTestVisible="False"/>

            </UniformGrid>

            <!-- 2 ряд -->

            <UniformGrid Columns="9"
                         Margin="30 0 30 5">

                <Button x:Name="A" Content="A" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="S" Content="S" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="D" Content="D" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="F" Content="F" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="G" Content="G" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="H" Content="H" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="J" Content="J" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="K" Content="K" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="L" Content="L" Height="45" IsHitTestVisible="False"/>

            </UniformGrid>

            <!-- 3 ряд -->

            <UniformGrid Columns="7"
                         Margin="70 0 70 10">

                <Button x:Name="Z" Content="Z" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="X" Content="X" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="C" Content="C" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="V" Content="V" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="B" Content="B" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="N" Content="N" Height="45" IsHitTestVisible="False"/>
                <Button x:Name="M" Content="M" Height="45" IsHitTestVisible="False"/>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>

</Window>
