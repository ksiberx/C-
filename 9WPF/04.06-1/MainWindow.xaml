<Window x:Class="OrdersApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказы" Height="450" Width="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <Button x:Name="btnCreate" Content="1. Создать XML" Click="BtnCreate_Click" Width="150" Height="40" Margin="5"/>
            <Button x:Name="btnReadDoc" Content="2. Читать XmlDocument" Click="BtnReadDoc_Click" Width="150" Height="40" Margin="5"/>
            <Button x:Name="btnReadReader" Content="3. Читать XmlTextReader" Click="BtnReadReader_Click" Width="150" Height="40" Margin="5"/>
        </StackPanel>

        <TextBox x:Name="txtOutput" Grid.Row="1" Margin="10" 
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"/>
    </Grid>
</Window>
