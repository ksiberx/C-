<Window x:Class="MonitorDiagonal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Диагональ монитора" Height="200" Width="350">
    <Grid>
        <StackPanel Margin="20">
            <Button x:Name="btn" Content="Узнать диагональ" Click="Btn_Click" 
                    Height="40" FontSize="16" Margin="0,0,0,20"/>
            <TextBlock x:Name="txtResult" FontSize="18" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
