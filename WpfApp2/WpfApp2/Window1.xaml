<Window x:Class="Pyatnashki.RulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Правила игры"
        Height="400"
        Width="600"
        Background="RosyBrown"
        ResizeMode="NoResize"
        Icon="C:\Users\murtm\source\repos\WpfApp2\WpfApp2\MyIcon.ico"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">

        <Border Background="LightYellow"
                CornerRadius="15"
                Padding="20">

            <StackPanel>

                <TextBlock Text="Правила игры Пятнашки"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"><Run Text="Поле 4 на 4 клетки, 15 фишек с цифрами от 1 до 15, одна клетка пустая. "/><LineBreak/><Run Text="Цель - расставить цифры по порядку: от 1 до 15, последняя клетка должна быть пустая. "/><LineBreak/><Run Text="Кликни на "/><Run Language="ru-ru" Text="кнопку"/><Run Text=" рядом с пустым местом "/><Run Text="-"/><Run Text=" она сдвинется. "/><LineBreak/><Run Text="Игра считается выигранной, когда все цифры стоят по порядку, а пустая клетка оказалась внизу справа."/></TextBlock>

                <Button Content="Закрыть"
                        Width="120"
                        Height="40"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Click="Close_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>